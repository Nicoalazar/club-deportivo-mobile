<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Header Azul Primario (#1B4F8A) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@color/colorPrimary"
        android:padding="16dp">

        <TextView
            android:id="@+id/btnVolverVencimientos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vencimientos"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"
            android:layout_marginStart="50dp"/>
    </RelativeLayout>

    <!-- Filtros (Botones Hoy, 7 días, Todos) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="15dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnHoy"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="Hoy"
            android:textAllCaps="false"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:layout_marginEnd="5dp"/>

        <Button
            android:id="@+id/btn7Dias"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="7 días"
            android:textAllCaps="false"
            android:backgroundTint="@color/white"
            android:textColor="@color/colorPrimary"
            android:layout_marginEnd="5dp"/>

        <Button
            android:id="@+id/btnTodos"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:text="Todos"
            android:textAllCaps="false"
            android:backgroundTint="@color/white"
            android:textColor="@color/colorPrimary"/>
    </LinearLayout>

    <!-- Contenedor Dinámico -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/contenedorSocios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">
            <!-- Aquí se inyectan los socios por código -->
        </LinearLayout>
    </ScrollView>

</LinearLayout>