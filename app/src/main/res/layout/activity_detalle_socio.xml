<?xml version="1.0" encoding="utf-8"?>
<!-- Contenedor Principal Vertical -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"> <!-- gris clarito -->

    <!-- 1. CABECERA (chicos creo q ahi estaria como  la pantalla anterior) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1B4F8A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp">

        <TextView
            android:id="@+id/btnVolverDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:padding="5dp"/>

        <TextView
            android:id="@+id/txtNombreSocioHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Juan Pérez"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- PERFIL (Chicos aca iba un circulo pero no entiendo asi que voy mas facil con un rectángulo) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp">

        <!-- Rectángulo  -->
        <TextView
            android:layout_width="100dp"
            android:layout_height="80dp"
            android:text="JP"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#7FB3D5" />

        <TextView
            android:id="@+id/txtNumeroCarnet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carnet N° 00042"
            android:textColor="#757575"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- Seccion de estado de cuota -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E8F5E9"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓  Cuota al día"
            android:textColor="#2E7D32"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vence el 10 de mayo de 2026"
            android:textColor="#2E7D32"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Seccion de datos personales -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginTop="15dp"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Datos personales"
            android:textColor="#1B4F8F"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- DNI -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="5dp">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="DNI:"
                android:textColor="#757575" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="38.123.456"
                android:textColor="#000000"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Email -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="5dp">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Email:"
                android:textColor="#757575" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="juan@mail.com"
                android:textColor="#000000"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Teléfono -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="5dp">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="Teléfono:"
                android:textColor="#757575" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11-4567-8901"
                android:textColor="#000000"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- seccion de ultimos pagos -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Últimos pagos"
        android:textColor="#1B4F8F"
        android:textStyle="bold"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp" />

    <!-- Pago 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="8dp"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10/04/2026"
                android:textColor="#757575"
                android:textSize="14sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Efectivo"
                android:textColor="#BDBDBD"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$3.500"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Pago 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="8dp"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10/03/2026"
                android:textColor="#757575"
                android:textSize="14sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transferencia"
                android:textColor="#BDBDBD"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$3.500"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- este espacio es para empujar el botón al final -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Botón Registar Pago -->
    <Button
        android:id="@+id/btnRegistrarPago"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="20dp"
        android:text="REGISTRAR PAGO"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1B4F8F" />

</LinearLayout>