<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    tools:context="com.grupo9.clubdeportivo.admin.socios.DetalleSocioActivity">

    <!-- Header Azul -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/colorPrimary"
        android:padding="16dp">

        <TextView
            android:id="@+id/btnVolverDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNombreTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btnVolverDetalle"
            android:layout_marginStart="20dp"
            android:text="Juan Pérez"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@android:drawable/btn_default_small"
                android:backgroundTint="@color/colorPrimary"
                android:gravity="center"
                android:text="JP"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNumCarnet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:text="Carnet N° 00042" />

            <TextView
                android:id="@+id/tvVencimientoCuota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@color/colorStatusOkLight"
                android:padding="15dp"
                android:text="✓ Cuota al día - Vence 10/05/2026"
                android:textColor="@color/colorStatusOk" />

            <TextView
                android:id="@+id/tvDniDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="DNI: 38.123.456" />


            <TextView    android:id="@+id/tvEmailDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email: ---"
                android:textSize="16sp"
                android:textColor="@color/colorTextMuted"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnRegistrarPago"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="30dp"
                android:backgroundTint="@color/colorPrimary"
                android:text="REGISTRAR PAGO"
                android:textColor="@android:color/white" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>